# Minimal makefile for Sphinx documentation
#

# You can set these variables from the command line, and also
# from the environment for the first two.
# -j auto: use all available CPU cores for parallel build (Unix only)
SPHINXOPTS    ?= -j auto
SPHINXBUILD   ?= sphinx-build
SOURCEDIR     = source
BUILDDIR      = build

# Base path for hosting (e.g., /sionna for GitLab Pages, empty for local/root hosting)
# Override with: make html BASE_PATH= (for local/root hosting)
BASE_PATH     ?= /sionna

# Put it first so that "make" without argument is like "make help".
help:
	@$(SPHINXBUILD) -M help "$(SOURCEDIR)" "$(BUILDDIR)" $(SPHINXOPTS) $(O)

.PHONY: help html clean Makefile

# Catch-all target: route all unknown targets to Sphinx using the new
# "make mode" option.  $(O) is meant as a shortcut for $(SPHINXOPTS).
%: Makefile
	@$(SPHINXBUILD) -M $@ "$(SOURCEDIR)" "$(BUILDDIR)" $(SPHINXOPTS) $(O)

# Clean build artifacts and autogenerated API docs
clean:
	@$(SPHINXBUILD) -M clean "$(SOURCEDIR)" "$(BUILDDIR)" $(SPHINXOPTS) $(O)
	@find "$(SOURCEDIR)" -name "sionna.*.rst" -delete 2>/dev/null || true

# Build HTML with version subdirectory and generate versions.json
html:
	@$(eval VERSION := $(shell python3 -c "import sys, os; sys.path.insert(0, os.path.abspath('../src')); from sionna import __version__; print(__version__)"))
	@echo "Building documentation for version $(VERSION)"
	# Standard build with separate doctrees directory
	@$(SPHINXBUILD) -b html -d "$(BUILDDIR)/doctrees" "$(SOURCEDIR)" "$(BUILDDIR)/html" $(SPHINXOPTS) $(O)
	# Fix nbsphinx image paths: copy images to _images/ and update HTML references.
	# nbsphinx emits broken relative paths to build/doctrees/nbsphinx/ with varying
	# depth depending on doc location:
	#   2 levels (e.g. rt/tutorials/) - from symlinked submodule sources
	#   3 levels (unused currently, but kept for robustness)
	#   4 levels (e.g. phy/tutorials/notebooks/, sys/tutorials/notebooks/)
	@if [ -d "$(BUILDDIR)/doctrees/nbsphinx" ]; then \
		mkdir -p "$(BUILDDIR)/html/_images"; \
		cp "$(BUILDDIR)/doctrees/nbsphinx/"*.png "$(BUILDDIR)/html/_images/" 2>/dev/null || true; \
		if [ "$$(uname)" = "Darwin" ]; then \
			find "$(BUILDDIR)/html" -name "*.html" -exec sed -i '' \
				-e 's|src="\.\./\.\./\.\./\.\./build/doctrees/nbsphinx/|src="../../../_images/|g' \
				-e 's|src="\.\./\.\./\.\./build/doctrees/nbsphinx/|src="../../_images/|g' \
				-e 's|src="\.\./\.\./build/doctrees/nbsphinx/|src="../../_images/|g' \
				-e 's|src="\.\./\.\./ext/build/doctrees/nbsphinx/|src="../../../_images/|g' \
				{} \; ; \
		else \
			find "$(BUILDDIR)/html" -name "*.html" -exec sed -i \
				-e 's|src="\.\./\.\./\.\./\.\./build/doctrees/nbsphinx/|src="../../../_images/|g' \
				-e 's|src="\.\./\.\./\.\./build/doctrees/nbsphinx/|src="../../_images/|g' \
				-e 's|src="\.\./\.\./build/doctrees/nbsphinx/|src="../../_images/|g' \
				-e 's|src="\.\./\.\./ext/build/doctrees/nbsphinx/|src="../../../_images/|g' \
				{} \; ; \
		fi; \
		echo "Fixed nbsphinx image paths"; \
	fi
	# Move to versioned folder
	@rm -rf "$(BUILDDIR)/html/v$(VERSION)"
	@mv "$(BUILDDIR)/html" "$(BUILDDIR)/html_temp"
	@mkdir -p "$(BUILDDIR)/html"
	@mv "$(BUILDDIR)/html_temp" "$(BUILDDIR)/html/v$(VERSION)"
	# Create version metadata and redirect
	@echo '[{"version": "$(VERSION)", "url": "$(BASE_PATH)/v$(VERSION)/"}, {"version": "0.19.2", "url": "https://jhoydis.github.io/sionna-0.19.2-doc/"}]' > "$(BUILDDIR)/html/versions.json"
	# Copy latest version to root for unversioned URLs (e.g., /phy/... -> /v2.0.0/phy/...)
	@cp -r "$(BUILDDIR)/html/v$(VERSION)/"* "$(BUILDDIR)/html/"
	@echo "Copied v$(VERSION) to root for unversioned URL support"


# Serve documentation locally with BASE_PATH simulation (no copying required)
# Usage: make serve [PORT=8000]
PORT ?= 8000
serve:
	@python3 serve.py --port $(PORT) --base-path "$(BASE_PATH)" --directory "$(BUILDDIR)/html"
